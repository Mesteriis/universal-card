{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM"],
    "allowJs": false,
    "checkJs": false,
    "noEmit": true,
    "strict": false,
    "alwaysStrict": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "useUnknownInCatchVariables": true,
    "types": []
  },
  "include": [
    "**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "coverage",
    "lazy",
    "scripts",
    "www",
    "universal-card.js",
    "build.js"
  ]
}
