{
  "name": "universal-card",
  "version": "1.0.5",
  "description": "Advanced Lovelace custom card for Home Assistant",
  "private": true,
  "scripts": {
    "build": "node build.js",
    "watch": "node build.js --watch",
    "dev": "node build.js --dev",
    "test:unit": "node scripts/test-regressions.js",
    "test:coverage": "vitest run --coverage",
    "test:coverage:expanded": "vitest run --config vitest.config.expanded.mjs --coverage",
    "test:config": "node scripts/test-config-validator.js",
    "test:e2e": "playwright test",
    "ha:fixture:up": "node scripts/ha-fixture-up.mjs",
    "ha:fixture:wait": "node scripts/ha-fixture-wait.mjs",
    "ha:fixture:onboard": "node scripts/ha-fixture-onboard.mjs",
    "ha:fixture:bootstrap": "node scripts/ha-fixture-bootstrap.mjs",
    "ha:fixture:down": "node scripts/ha-fixture-down.mjs",
    "ha:fixture:reset": "node scripts/ha-fixture-reset.mjs",
    "screenshots:ha": "playwright test -c playwright.screenshots.config.ts",
    "docs:assets:refresh": "node scripts/export-docs-assets.mjs",
    "smoke:themes-modes": "node scripts/smoke-theme-mode-matrix.js",
    "smoke:runtime": "node scripts/smoke-runtime-optimizations.js",
    "test": "npm run test:config && npm run test:unit && npm run typecheck && npm run build && npm run smoke:themes-modes && npm run smoke:runtime",
    "check": "npm run test",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@vitest/coverage-v8": "^4.0.18",
    "esbuild": "^0.20.0",
    "jsdom": "^28.1.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mesteriis/universal-card.git"
  },
  "author": "Mesteriis",
  "license": "MIT"
}
